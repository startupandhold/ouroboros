{
  "name": "ouroboros-incinerator",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev",
    "build": "npm run db:generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "npx prisma@5.22.0 generate",
    "db:migrate": "npx prisma@5.22.0 migrate dev",
    "db:migrate:deploy": "npx prisma@5.22.0 migrate deploy",
    "db:push": "npx prisma@5.22.0 db push",
    "db:import-json": "npx --yes tsx scripts/import-burn-history-json.ts",
    "sync:burn-history": "npx --yes tsx scripts/sync-burn-history.ts"
  },
  "dependencies": {
    "@coin-communities/sdk": "^1.0.1",
    "@metaplex-foundation/mpl-token-metadata": "^3.4.0",
    "@metaplex-foundation/umi": "^1.5.1",
    "@metaplex-foundation/umi-bundle-defaults": "^1.5.1",
    "@prisma/client": "5.22.0",
    "@solana/spl-token": "^0.4.13",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-react-ui": "^0.9.39",
    "@solana/wallet-adapter-wallets": "^0.19.38",
    "@solana/web3.js": "^1.98.4",
    "bs58": "^6.0.0",
    "next": "^16.2.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "use-sound": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.18",
    "prisma": "5.22.0",
    "typescript": "^5.6.3"
  }
}
