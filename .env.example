# Copy to `.env.local` for local development (Next.js loads it automatically).
# Do not commit `.env.local` — it is gitignored.

# -----------------------------------------------------------------------------
# Solana RPC
# -----------------------------------------------------------------------------
# Optional. If unset, the app uses the public Solana mainnet-beta endpoint.
#
# SECURITY: `NEXT_PUBLIC_*` variables are embedded in the browser bundle. Treat
# any URL you put here as public (visitors can read it). Use an RPC provider key
# that is referrer-locked, IP-limited, or otherwise scoped — not a root API secret.
#
# Examples (placeholders only):
# NEXT_PUBLIC_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# NEXT_PUBLIC_SOLANA_RPC_URL=https://YOUR_ENDPOINT.solana-mainnet.quiknode.pro/YOUR_KEY/
NEXT_PUBLIC_SOLANA_RPC_URL=

# -----------------------------------------------------------------------------
# Helius (optional — improves token metadata via DAS getAsset)
# -----------------------------------------------------------------------------
# If your RPC above is already a `*.helius-rpc.com` URL, the app reuses it for
# DAS calls. Otherwise set a Helius API key here for metadata fallback only.
# NEXT_PUBLIC_HELIUS_API_KEY=YOUR_HELIUS_KEY
#
# Server-only Helius key (preferred for burn-history indexing — not in client bundle):
# HELIUS_API_KEY=YOUR_HELIUS_KEY
#
# Neon Postgres — burn history (Prisma 5). Required for burn history API + UI.
# NEON_DB_URL=postgresql://user:pass@host/neondb?sslmode=require
#
# Use npm scripts (not bare `npx prisma` — that installs Prisma 7 and breaks the schema):
#   npm run db:migrate:deploy   apply migrations
#   npm run db:push             schema push without migration files
#
# One-time import from data/ouro-burn-history.json: npm run db:import-json
# On-chain OURO burns: npm run sync:burn-history (Helius; no exchange inference).
# Human trash→OURO exchanges are POSTed from the app after each incineration.

# -----------------------------------------------------------------------------
# Sol Incinerator API (optional)
# -----------------------------------------------------------------------------
# Server-only — not `NEXT_PUBLIC_*`. The app proxies v2 requests through
# `/api/sol-incinerator/*` so the key stays off the client.
#
# Enables OUROBOROS burn via POST /burn and empty-account closes via
# POST /batch/close-all when set. If unset, the same flows use local SPL ix.
#
# Docs: https://api.dashboard.sol-incinerator.com/docs/v2#authentication
SOL_INCINERATOR_API=


# NEON_DB_URL=
